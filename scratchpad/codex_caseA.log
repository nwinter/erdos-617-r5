+      have hp : (r - 1) * qp ≤ (r - 1) * 1 := Nat.mul_le_mul_left _ hqple'
+      omega
+    have hqpval : qp = 2 := by omega
+    have hspval : sp = 1 := by omega
+    have hqval : q = 2 := by
+      rw [hqdef, hnval]
+      simp [mul_comm]
+    have hsval : s = 0 := by
+      rw [hsdef, hnval]
+      simp [mul_comm]
+    subst qp
+    subst sp
+    subst q
+    subst s
+    omega
+  · omega
 
