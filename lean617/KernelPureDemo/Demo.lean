import Mathlib.Tactic.Sat.FromLRAT

-- `m9_kernel_pure`: kernel-checked UNSAT of the M9 CNF (Î±â‰¤2, Ď‰â‰¤4, cap-11, â‰¤18 edges on
-- 9 vertices), via Mathlib's proof-term-producing LRAT replay. Axiom-pure.
-- (`lrat_proof` is a command, so no `/-- -/` doc-comment may precede it.)
lrat_proof m9_kernel_pure
  (include_str "M9.cnf")
  (include_str "M9.core.lrat")

#print axioms m9_kernel_pure
